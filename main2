#define F_CPU 8000000UL
#include <avr/io.h>
#include <avr/interrupt.h>
#include <util/delay.h>
#include <string.h>
#include "aes.h"

#define TRIG_DDR   DDRB
#define TRIG_PORT  PORTB
#define TRIG_PIN   PB0

static const uint8_t key[16] = {
    0x2B, 0x7E, 0x15, 0x16,
    0x28, 0xAE, 0xD2, 0xA6,
    0xAB, 0xF7, 0x15, 0x88,
    0x09, 0xCF, 0x4F, 0x3C
};

static uint32_t lfsr_state = 0xACE1BEEF;

static uint8_t lfsr_byte(void) {
    uint8_t out = 0;
    for (uint8_t i = 0; i < 8; i++) {
        uint32_t bit = lfsr_state & 1u;
        lfsr_state >>= 1;
        if (bit) lfsr_state ^= 0xD0000001u;
        out = (out << 1) | (uint8_t)bit;
    }
    return out;
}

static void fill_random_plaintext(uint8_t *pt) {
    for (uint8_t i = 0; i < 16; i++) {
        pt[i] = lfsr_byte();
    }
}

int main(void) {
    TRIG_DDR |= (1 << TRIG_PIN);
    TRIG_PORT &= ~(1 << TRIG_PIN);
    
    // Disable all peripherals / interrupts during the whole operation
    // to keep the chip quiet
    cli();
    
    _delay_ms(2000);
    
    uint8_t plaintext[16];
    uint8_t ciphertext[16];
    
    struct AES_ctx ctx;
    AES_init_ctx(&ctx, key);
    
    while (1) {
        fill_random_plaintext(plaintext);
        memcpy(ciphertext, plaintext, 16);
        
        // Long quiet delay before measurement — lets power settle
        _delay_ms(50);
        
        // ===== MEASURED ENCRYPTION =====
        TRIG_PORT |= (1 << TRIG_PIN);
        asm volatile(
            "nop\n" "nop\n" "nop\n" "nop\n"
            "nop\n" "nop\n" "nop\n" "nop\n"
        );
        AES_ECB_encrypt(&ctx, ciphertext);
        TRIG_PORT &= ~(1 << TRIG_PIN);
        
        _delay_ms(100);
    }
}
